import os

def add_book():
    book_id = input("Enter book ID: ")
    title = input("Enter book title: ")
    author = input("Enter author name: ")
    with open('books.txt', 'a') as file:
        file.write(f"{book_id},{title},{author}\n")
    print("Book added successfully.")

def view_books():
    try:
        with open('books.txt', 'r') as file:
            for line in file:
                book_id, title, author = line.strip().split(',')
                print(f"ID: {book_id}, Title: {title}, Author: {author}")
    except FileNotFoundError:
        print("No books found.")

def update_book():
    book_id = input("Enter book ID to update: ")
    updated_title = input("Enter new title: ")
    updated_author = input("Enter new author: ")

    updated_lines = []
    found = False

    try:
        with open('books.txt', 'r') as file:
            for line in file:
                id, title, author = line.strip().split(',')
                if id == book_id:
                    updated_lines.append(f"{book_id},{updated_title},{updated_author}\n")
                    found = True
                else:
                    updated_lines.append(line)

        if found:
            with open('books.txt', 'w') as file:
                file.writelines(updated_lines)
            print("Book updated successfully.")
        else:
            print("Book ID not found.")
    except FileNotFoundError:
        print("No books found.")

def delete_book():
    book_id = input("Enter book ID to delete: ")

    updated_lines = []
    found = False

    try:
        with open('books.txt', 'r') as file:
            for line in file:
                id, title, author = line.strip().split(',')
                if id != book_id:
                    updated_lines.append(line)
                else:
                    found = True

        if found:
            with open('books.txt', 'w') as file:
                file.writelines(updated_lines)
            print("Book deleted successfully.")
        else:
            print("Book ID not found.")
    except FileNotFoundError:
        print("No books found.")


